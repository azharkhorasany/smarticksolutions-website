---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SITE } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  article
  pubDate={post.data.pubDate}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "author": {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
    },
    "publisher": {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
    },
  })} />

  <Header />
  <main id="main-content">
    <!-- Article header -->
    <section class="bg-navy-dark py-16 md:py-20">
      <div class="container-custom">
        <div class="max-w-3xl">
          <a href="/blog" class="inline-flex items-center gap-1.5 text-gray-400 hover:text-white text-sm mb-6 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Back to Blog
          </a>

          <span class="inline-block text-xs font-semibold bg-scarlet/20 text-scarlet border border-scarlet/30 px-3 py-1 rounded-full mb-4">
            {post.data.category}
          </span>

          <h1 class="text-3xl md:text-5xl font-extrabold text-white text-balance leading-tight">
            {post.data.title}
          </h1>

          <p class="text-gray-300 mt-4 text-lg leading-relaxed">
            {post.data.description}
          </p>

          <div class="flex flex-wrap items-center gap-4 mt-6 text-sm text-gray-400">
            <span>{post.data.author}</span>
            <span>·</span>
            <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
            {post.data.readingTime && (
              <>
                <span>·</span>
                <span>{post.data.readingTime} min read</span>
              </>
            )}
          </div>

          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-5">
              {post.data.tags.map((tag) => (
                <span class="text-xs px-2.5 py-1 bg-white/10 text-gray-300 rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Article body -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <article class="prose prose-lg prose-navy max-w-none
            prose-headings:text-navy-dark prose-headings:font-bold
            prose-a:text-scarlet prose-a:no-underline hover:prose-a:underline
            prose-strong:text-navy-dark
            prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
            prose-blockquote:border-l-scarlet prose-blockquote:text-gray-500
            prose-li:text-gray-600 prose-p:text-gray-600
            prose-hr:border-gray-200
          ">
            <Content />
          </article>

          <hr class="my-12 border-gray-200" />

          <!-- Article footer -->
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-navy hover:text-scarlet transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
              </svg>
              Back to all articles
            </a>
            <a href="/contact" class="btn-primary text-sm">
              Discuss a Project
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTABanner
      title="Ready to Put This Into Practice?"
      subtitle="Let's talk about your project and how we can help you get there."
      primaryCta={{ label: 'Get in Touch', href: '/contact' }}
      secondaryCta={{ label: 'View Services', href: '/services' }}
    />
  </main>
  <Footer />
</BaseLayout>
