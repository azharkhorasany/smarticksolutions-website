---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
import { SITE } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  article
  pubDate={post.data.pubDate}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "author": { "@type": "Organization", "name": SITE.name, "url": SITE.url },
    "publisher": { "@type": "Organization", "name": SITE.name, "url": SITE.url },
  })} />

  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] z-50 transition-none" style="width:0%; background: linear-gradient(90deg, #c90019, #E8001D, #ff3347);" aria-hidden="true"></div>

  <Header />
  <main id="main-content">

    <!-- Article header -->
    <section
      class="relative overflow-hidden py-20 md:py-28"
      style="background: linear-gradient(135deg, #070838 0%, #0f1360 55%, #1B1F8A 100%);"
    >
      <!-- Dot grid -->
      <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.10) 1px, transparent 1px); background-size: 26px 26px;" aria-hidden="true"></div>
      <!-- Scarlet glow -->
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 55% 70% at 90% 10%, rgba(232,0,29,0.14) 0%, transparent 60%);" aria-hidden="true"></div>

      <!-- Geometric decoration — right side, desktop only -->
      <div class="absolute right-0 top-0 h-full w-1/2 hidden lg:block pointer-events-none" aria-hidden="true">
        <svg class="absolute right-0 top-0 h-full w-full opacity-[0.16]" viewBox="0 0 600 280" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid lines -->
          <line x1="80"  y1="0"   x2="80"  y2="280" stroke="white" stroke-width="1"/>
          <line x1="200" y1="0"   x2="200" y2="280" stroke="white" stroke-width="1"/>
          <line x1="340" y1="0"   x2="340" y2="280" stroke="white" stroke-width="1"/>
          <line x1="480" y1="0"   x2="480" y2="280" stroke="white" stroke-width="1"/>
          <line x1="0"   y1="70"  x2="600" y2="70"  stroke="white" stroke-width="1"/>
          <line x1="0"   y1="140" x2="600" y2="140" stroke="white" stroke-width="1"/>
          <line x1="0"   y1="210" x2="600" y2="210" stroke="white" stroke-width="1"/>
          <!-- Junction nodes -->
          <circle cx="80"  cy="70"  r="4" fill="white"/>
          <circle cx="200" cy="70"  r="4" fill="white"/>
          <circle cx="340" cy="70"  r="4" fill="white"/>
          <circle cx="480" cy="70"  r="4" fill="white"/>
          <circle cx="80"  cy="140" r="4" fill="white"/>
          <circle cx="200" cy="140" r="7" fill="white"/>
          <circle cx="340" cy="140" r="4" fill="white"/>
          <circle cx="480" cy="140" r="7" fill="white"/>
          <circle cx="80"  cy="210" r="4" fill="white"/>
          <circle cx="200" cy="210" r="4" fill="white"/>
          <circle cx="340" cy="210" r="7" fill="white"/>
          <circle cx="480" cy="210" r="4" fill="white"/>
          <!-- Circuit traces -->
          <path d="M 80 70 L 140 70 L 140 105 L 200 105" stroke="white" stroke-width="2"/>
          <path d="M 200 140 L 270 140 L 270 175 L 340 175 L 340 210" stroke="white" stroke-width="2"/>
          <path d="M 340 70  L 410 70  L 410 140 L 480 140" stroke="white" stroke-width="1.5"/>
          <path d="M 80  210 L 80  175 L 140 175 L 140 140 L 200 140" stroke="white" stroke-width="1.5"/>
          <!-- Chip box -->
          <rect x="148" y="108" width="104" height="64" rx="6" stroke="white" stroke-width="1.5" fill="none"/>
          <rect x="158" y="118" width="84"  height="44" rx="3" stroke="white" stroke-width="1" fill="white" fill-opacity="0.04"/>
          <!-- Chip pins left -->
          <line x1="148" y1="122" x2="128" y2="122" stroke="white" stroke-width="1.5"/>
          <line x1="148" y1="138" x2="128" y2="138" stroke="white" stroke-width="1.5"/>
          <line x1="148" y1="154" x2="128" y2="154" stroke="white" stroke-width="1.5"/>
          <!-- Chip pins right -->
          <line x1="252" y1="122" x2="272" y2="122" stroke="white" stroke-width="1.5"/>
          <line x1="252" y1="138" x2="272" y2="138" stroke="white" stroke-width="1.5"/>
          <line x1="252" y1="154" x2="272" y2="154" stroke="white" stroke-width="1.5"/>
          <!-- Concentric rings — top right -->
          <circle cx="530" cy="48"  r="46" stroke="white" stroke-width="1"   fill="none"/>
          <circle cx="530" cy="48"  r="28" stroke="white" stroke-width="1"   fill="none"/>
          <circle cx="530" cy="48"  r="12" fill="white" fill-opacity="0.18"/>
          <line   x1="484" y1="48"  x2="502" y2="48"  stroke="white" stroke-width="1"/>
          <circle cx="484" cy="48"  r="3"  fill="white"/>
          <!-- Hexagon — bottom right -->
          <polygon points="510,230 540,248 540,284 510,302 480,284 480,248" stroke="white" stroke-width="1.5" fill="none"/>
          <circle cx="510" cy="265" r="5" fill="white" fill-opacity="0.35"/>
          <!-- Diamond accent -->
          <polygon points="430,175 445,190 430,205 415,190" stroke="white" stroke-width="1.5" fill="none"/>
          <circle cx="430" cy="190" r="3" fill="white" fill-opacity="0.4"/>
        </svg>
        <!-- Accent rings -->
        <div class="absolute right-12 top-1/2 -translate-y-1/2 w-48 h-48 rounded-full border border-white/[0.08] flex items-center justify-center">
          <div class="w-32 h-32 rounded-full border border-white/[0.08] flex items-center justify-center">
            <div class="w-16 h-16 rounded-full border border-scarlet/25 hero-pulse"></div>
          </div>
        </div>
      </div>

      <div class="container-custom relative z-10">
        <div class="max-w-3xl">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 text-gray-400 hover:text-white text-sm mb-8 transition-colors group"
          >
            <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Back to Blog
          </a>

          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="text-xs font-bold uppercase tracking-wide text-scarlet bg-scarlet/15 border border-scarlet/30 px-3 py-1 rounded-full">
              {post.data.category}
            </span>
            {post.data.readingTime && (
              <span class="text-xs text-gray-400">{post.data.readingTime} min read</span>
            )}
          </div>

          <h1
            class="text-3xl md:text-5xl font-extrabold text-white leading-tight text-balance mb-5"
            style="letter-spacing: -0.03em;"
          >
            {post.data.title}
          </h1>

          <p class="text-gray-300 text-lg leading-relaxed mb-8 max-w-2xl">
            {post.data.description}
          </p>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-400 pt-6 border-t border-white/10">
            <span class="font-medium text-gray-300">{post.data.author}</span>
            <span aria-hidden="true">·</span>
            <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          </div>

          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-5">
              {post.data.tags.map((tag) => (
                <span class="text-xs px-2.5 py-1 bg-white/8 text-gray-400 border border-white/10 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Article body -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <article class="prose prose-lg max-w-none">
            <Content />
          </article>

          <hr class="my-12 border-gray-200" />

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 text-sm font-semibold text-navy hover:text-scarlet transition-colors group"
            >
              <svg class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
              </svg>
              Back to all articles
            </a>
            <a href="/contact" class="btn-primary text-sm">
              Discuss a Project
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTABanner
      title="Ready to Put This Into Practice?"
      subtitle="Let's talk about your project and how we can help you get there."
      primaryCta={{ label: 'Get in Touch', href: '/contact' }}
      secondaryCta={{ label: 'View Services', href: '/services' }}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    const update = () => {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
