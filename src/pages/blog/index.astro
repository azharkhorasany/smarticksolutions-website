---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryColours: Record<string, string> = {
  'Software Development': 'bg-blue-100 text-blue-700',
  'Integration Services': 'bg-emerald-100 text-emerald-700',
  'Mobile Development': 'bg-red-100 text-red-700',
};
---

<BaseLayout
  title="Blog"
  description="Insights on bespoke software development, API integrations, mobile apps, and technology strategy for UK businesses — from the Smartick Solutions team."
>
  <Header />
  <main id="main-content">
    <Hero
      title="Insights & Articles"
      subtitle="Practical guidance on software development, integrations, and technology strategy — written for business owners and decision-makers, not just developers."
      compact
      badge="Blog"
    />

    <section class="py-20 md:py-28 bg-white">
      <div class="container-custom">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post, i) => {
            const categoryClass = categoryColours[post.data.category] ?? 'bg-gray-100 text-gray-700';
            const formattedDate = post.data.pubDate.toLocaleDateString('en-GB', {
              day: 'numeric', month: 'long', year: 'numeric',
            });

            return (
              <article class="card group overflow-hidden reveal" style={`transition-delay: ${i * 80}ms`}>
                <div class="h-2 bg-gradient-to-r from-navy to-scarlet"></div>
                <div class="p-7">
                  <div class="flex items-center gap-3 mb-4">
                    <span class={`text-xs font-semibold px-3 py-1 rounded-full ${categoryClass}`}>
                      {post.data.category}
                    </span>
                    {post.data.readingTime && (
                      <span class="text-xs text-gray-400">{post.data.readingTime} min read</span>
                    )}
                    {post.data.featured && (
                      <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full">Featured</span>
                    )}
                  </div>

                  <h2 class="font-bold text-navy-dark leading-snug mb-3 group-hover:text-scarlet transition-colors">
                    <a href={`/blog/${post.slug}`} class="hover:underline underline-offset-2">
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="text-gray-500 text-sm leading-relaxed mb-5">
                    {post.data.description}
                  </p>

                  <div class="flex items-center justify-between text-xs text-gray-400">
                    <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                    <a
                      href={`/blog/${post.slug}`}
                      class="text-scarlet font-semibold hover:underline flex items-center gap-1"
                    >
                      Read more
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        {posts.length === 0 && (
          <div class="text-center py-16 text-gray-400">
            <p class="text-lg">No posts yet — check back soon.</p>
          </div>
        )}
      </div>
    </section>

    <CTABanner
      title="Want to Work With Us?"
      subtitle="Reading our thinking is great. Building something together is better."
      primaryCta={{ label: 'Start a Project', href: '/contact' }}
      secondaryCta={{ label: 'View Services', href: '/services' }}
    />
  </main>
  <Footer />
</BaseLayout>
