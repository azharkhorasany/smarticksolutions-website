---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = allPosts.find(p => p.data.featured) ?? null;
const gridPosts    = featuredPost ? allPosts.filter(p => p !== featuredPost) : allPosts;

const categoryColours: Record<string, string> = {
  'Software Development':  'bg-navy-50 text-navy-700 ring-1 ring-inset ring-navy-200',
  'Integration Services':  'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200',
  'Mobile Development':    'bg-scarlet-50 text-scarlet-600 ring-1 ring-inset ring-scarlet-200',
  'Website Development':   'bg-violet-50 text-violet-700 ring-1 ring-inset ring-violet-200',
  'Technology Strategy':   'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog"
  description="Insights on bespoke software development, API integrations, mobile apps, and technology strategy for UK businesses — from the Smartick Solutions team."
>
  <Header />
  <main id="main-content">
    <Hero
      title="Insights & Articles"
      subtitle="Practical guidance on software development, integrations, and technology strategy — written for business owners and decision-makers, not just developers."
      compact
      badge="Blog"
    />

    {featuredPost && (
      <section class="pt-20 pb-4 md:pt-28 md:pb-6 bg-white">
        <div class="container-custom">
          <div class="reveal mb-8">
            <p class="section-label">Featured Article</p>
          </div>

          <a href={`/blog/${featuredPost.slug}`} class="group block reveal">
            <article
              class="relative overflow-hidden rounded-2xl"
              style="background: linear-gradient(135deg, #070838 0%, #0f1360 55%, #1B1F8A 100%);"
            >
              <!-- Dot grid -->
              <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.10) 1px, transparent 1px); background-size: 26px 26px;" aria-hidden="true"></div>
              <!-- Scarlet glow -->
              <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 80% at 95% 5%, rgba(232,0,29,0.16) 0%, transparent 60%);" aria-hidden="true"></div>

              <div class="relative z-10 p-10 md:p-14 lg:p-16">
                <div class="flex flex-wrap items-center gap-3 mb-6">
                  <span class="text-xs font-bold uppercase tracking-wide text-scarlet bg-scarlet/15 border border-scarlet/30 px-3 py-1 rounded-full">
                    {featuredPost.data.category}
                  </span>
                  {featuredPost.data.readingTime && (
                    <span class="text-xs text-gray-400">{featuredPost.data.readingTime} min read</span>
                  )}
                </div>

                <h2
                  class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-5 max-w-3xl group-hover:text-scarlet-300 transition-colors duration-300"
                  style="letter-spacing: -0.03em;"
                >
                  {featuredPost.data.title}
                </h2>

                <p class="text-gray-300 text-base md:text-lg leading-relaxed mb-10 max-w-2xl">
                  {featuredPost.data.description}
                </p>

                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-6 border-t border-white/10">
                  <div class="flex items-center gap-3 text-sm text-gray-400">
                    <span>{featuredPost.data.author}</span>
                    <span aria-hidden="true">·</span>
                    <time datetime={featuredPost.data.pubDate.toISOString()}>
                      {formatDate(featuredPost.data.pubDate)}
                    </time>
                  </div>
                  <span class="inline-flex items-center gap-2 font-bold text-sm text-white group-hover:gap-3 transition-all duration-200">
                    Read Article
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                </div>
              </div>
            </article>
          </a>
        </div>
      </section>
    )}

    {gridPosts.length > 0 && (
      <section class={`bg-white ${featuredPost ? 'pt-14 pb-20 md:pb-28' : 'py-20 md:py-28'}`}>
        <div class="container-custom">
          {featuredPost && (
            <div class="reveal mb-10">
              <p class="section-label">More Articles</p>
            </div>
          )}

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {gridPosts.map((post, i) => {
              const categoryClass = categoryColours[post.data.category] ?? 'bg-gray-100 text-gray-600 ring-1 ring-inset ring-gray-200';
              return (
                <article
                  class="card group relative flex flex-col overflow-hidden reveal"
                  style={`transition-delay: ${i * 80}ms`}
                >
                  <div class="flex flex-col flex-1 p-7">
                    <div class="flex items-center justify-between mb-4">
                      <span class={`text-xs font-bold px-2.5 py-1 rounded-md ${categoryClass}`}>
                        {post.data.category}
                      </span>
                      {post.data.readingTime && (
                        <span class="text-xs text-gray-400 tabular-nums">{post.data.readingTime} min read</span>
                      )}
                    </div>

                    <h2
                      class="font-extrabold text-navy-950 leading-snug mb-3 group-hover:text-scarlet transition-colors duration-200"
                      style="letter-spacing: -0.02em; font-size: 1.05rem;"
                    >
                      <a href={`/blog/${post.slug}`} class="after:absolute after:inset-0">
                        {post.data.title}
                      </a>
                    </h2>

                    <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-6">
                      {post.data.description}
                    </p>

                    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                      <time class="text-xs text-gray-400" datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                      <span class="inline-flex items-center gap-1 text-xs font-bold text-scarlet group-hover:gap-2 transition-all duration-200" aria-hidden="true">
                        Read more
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                      </span>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <section class="py-24 bg-white">
        <div class="container-custom text-center text-gray-400">
          <p class="text-lg">No posts yet — check back soon.</p>
        </div>
      </section>
    )}

    <CTABanner
      title="Want to Work With Us?"
      subtitle="Reading our thinking is great. Building something together is better."
      primaryCta={{ label: 'Start a Project', href: '/contact' }}
      secondaryCta={{ label: 'View Services', href: '/services' }}
    />
  </main>
  <Footer />
</BaseLayout>
