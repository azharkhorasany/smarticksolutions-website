---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTABanner from '../components/CTABanner.astro';

const websitePackages = [
  {
    name: 'Starter',
    price: 'From Only £99',
    description: 'Perfect for startups and small businesses that need a professional web presence quickly.',
    features: [
      'Up to 5 pages',
      'Mobile-responsive design',
      'Contact form',
      'Basic on-page SEO',
      '1 round of revisions',
      '30-day post-launch support',
    ],
    cta: 'Get Started',
    highlighted: false,
  },
  {
    name: 'Business',
    price: 'From £799',
    description: 'For growing businesses that need a fully-featured website that performs and converts.',
    features: [
      'Everything in Starter, plus:',
      'Up to 15 pages',
      'Custom UI design',
      'CMS integration',
      'Full technical SEO',
      'Performance optimisation',
      'E-commerce ready',
      '2 rounds of revisions',
      '60-day post-launch support',
    ],
    cta: 'Most Popular',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom quote',
    description: 'Complex requirements, custom integrations, and bespoke functionality — quoted per project.',
    features: [
      'Everything in Business, plus:',
      'Unlimited pages',
      'Custom backend & API',
      'Third-party integrations',
      'Advanced SEO & Core Web Vitals',
      'Accessibility compliance',
      'Priority support',
    ],
    cta: 'Request a Quote',
    highlighted: false,
  },
];

const retainerPlans = [
  {
    name: 'Support',
    price: 'From £249/mo',
    description: 'For teams that need reactive support and maintenance.',
    includes: ['Bug fixes & patches', 'Security updates', '4 hrs development/month', 'Email support'],
  },
  {
    name: 'Growth',
    price: 'From £549/mo',
    description: 'Ongoing development partnership for continuous improvement.',
    includes: ['Everything in Support', '10 hrs development/month', 'Monthly strategy call', 'Priority response'],
  },
  {
    name: 'Partner',
    price: 'From £949/mo',
    description: 'A dedicated development team for businesses serious about technology.',
    includes: ['Everything in Growth', '25 hrs development/month', 'Weekly check-ins', 'Architecture reviews'],
  },
];

const faqs = [
  {
    q: 'Do you charge hourly or fixed-price?',
    a: 'We strongly prefer fixed-price projects. We agree a clear scope and price before any work begins — no surprises, no scope creep invoices. For genuinely ongoing or evolving work, we use monthly retainers with a fixed hours allocation.',
  },
  {
    q: 'How quickly can you start?',
    a: 'Typically 2–4 weeks from signing. We are selective about the projects we take on so we can give every client the attention they deserve. For urgent projects, contact us — we may be able to accommodate a faster start.',
  },
  {
    q: 'Do I need a large budget?',
    a: 'Not necessarily. Our Starter Web package begins at only £99. We\'re transparent about costs in our first conversation — if your budget doesn\'t match your requirements, we\'ll tell you clearly and explore what\'s achievable within your means.',
  },
  {
    q: 'What happens after the project launches?',
    a: 'Clients on a support retainer get ongoing maintenance and full management of the codebase — we stay close to the code so we can move quickly when you need us. If you ever decide to move on, we\'re happy to have a conversation about what a transition looks like for your situation.',
  },
  {
    q: 'Do you work with businesses outside the UK?',
    a: 'Our team is UK-based and our primary market is UK businesses, but we do work with international clients where a good fit exists. Contact us to discuss your situation.',
  },
];
---

<BaseLayout
  title="Software Development Pricing UK | Fixed-Price Projects"
  description="Transparent, fixed-price packages for websites, bespoke software, and monthly retainers. No hidden costs — you know the price before we start."
  breadcrumbs={[{ name: 'Pricing', url: '/pricing' }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a },
    })),
  })} />
  <Header />
  <main id="main-content">
    <Hero
      title="Transparent Pricing"
      subtitle="Fixed-price projects. No hidden costs. No surprise invoices. You'll always know exactly what you're paying before we start."
      compact
      badge="Pricing"
    />

    <!-- Website packages -->
    <section class="py-20 md:py-28 bg-white">
      <div class="container-custom">
        <div class="text-center reveal">
          <p class="section-label">Website Development</p>
          <h2 class="section-title mx-auto">Website Packages</h2>
          <p class="section-subtitle mx-auto">
            Clear, fixed-price packages for your web presence. All prices exclude VAT.
          </p>
        </div>

        <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-8">
          {websitePackages.map((pkg, i) => (
            <article
              class={`rounded-xl p-8 flex flex-col reveal ${
                pkg.highlighted
                  ? 'bg-navy shadow-xl ring-2 ring-scarlet text-white'
                  : 'card'
              }`}
              style={`transition-delay: ${i * 100}ms`}
            >
              {pkg.highlighted && (
                <span class="inline-block self-start text-xs font-bold px-3 py-1 bg-scarlet text-white rounded-full mb-4">
                  Most Popular
                </span>
              )}
              <h3 class={`text-xl font-bold ${pkg.highlighted ? 'text-white' : 'text-navy-dark'}`}>{pkg.name}</h3>
              <p class={`text-3xl font-extrabold mt-2 mb-3 ${pkg.highlighted ? 'text-white' : 'text-navy'}`}>{pkg.price}</p>
              <p class={`text-sm mb-6 leading-relaxed ${pkg.highlighted ? 'text-navy-100' : 'text-gray-500'}`}>{pkg.description}</p>

              <ul class="space-y-3 mb-8 flex-1">
                {pkg.features.map((feature) => (
                  feature.startsWith('Everything in') ? (
                    <li class={`text-xs font-bold uppercase tracking-wider pt-1 pb-0.5 ${pkg.highlighted ? 'text-scarlet' : 'text-scarlet'}`}>
                      {feature}
                    </li>
                  ) : (
                    <li class="flex items-start gap-2 text-sm">
                      <svg class="h-4 w-4 mt-0.5 flex-shrink-0 text-scarlet" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class={pkg.highlighted ? 'text-navy-100' : 'text-gray-600'}>{feature}</span>
                    </li>
                  )
                ))}
              </ul>

              <a
                href="/contact"
                class={`text-center font-semibold px-6 py-3 rounded-lg transition-colors duration-200 text-sm
                  ${pkg.highlighted
                    ? 'bg-scarlet text-white hover:bg-scarlet-dark'
                    : 'bg-gray-100 text-navy hover:bg-navy hover:text-white'}`}
              >
                {pkg.highlighted ? 'Get Started' : pkg.cta}
              </a>
            </article>
          ))}
        </div>

        <!-- Bespoke note -->
        <div class="mt-10 rounded-xl bg-gray-50 border border-gray-200 p-6 text-center reveal">
          <p class="text-gray-600 text-sm">
            <strong class="text-navy-dark">Need bespoke software, mobile apps, or integrations?</strong>{' '}
            These are always quoted per project after a discovery call — there's no standard package because every requirement is unique.{' '}
            <a href="/contact" class="text-scarlet font-semibold hover:underline">Let's talk →</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Retainer plans -->
    <section class="py-20 md:py-24 bg-gray-50">
      <div class="container-custom">
        <div class="text-center reveal">
          <p class="section-label">Ongoing Partnership</p>
          <h2 class="section-title mx-auto">Support & Retainer Plans</h2>
          <p class="section-subtitle mx-auto">
            Once your project is live, keep it running, growing, and up to date with a monthly retainer.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
          {retainerPlans.map((plan, i) => (
            <div class="card p-7 reveal" style={`transition-delay: ${i * 100}ms`}>
              <h3 class="text-lg font-bold text-navy-dark">{plan.name}</h3>
              <p class="text-2xl font-extrabold text-scarlet mt-1 mb-3">{plan.price}</p>
              <p class="text-gray-500 text-sm mb-5">{plan.description}</p>
              <ul class="space-y-2">
                {plan.includes.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="h-4 w-4 text-scarlet mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 md:py-24 bg-white">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <div class="text-center reveal">
            <p class="section-label">Questions</p>
            <h2 class="section-title mx-auto">Frequently Asked Questions</h2>
          </div>

          <div class="mt-12 space-y-4">
            {faqs.map((faq, i) => (
              <details class="card p-6 group reveal" style={`transition-delay: ${i * 60}ms`}>
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none font-semibold text-navy-dark">
                  {faq.q}
                  <svg class="h-5 w-5 text-gray-400 flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <p class="text-gray-600 text-sm leading-relaxed mt-4">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <CTABanner
      title="Not Sure Which Option Is Right for You?"
      subtitle="Book a free 30-minute discovery call and we'll help you figure out the best approach and a realistic budget."
      primaryCta={{ label: 'Book a Discovery Call', href: '/contact' }}
      secondaryCta={{ label: 'See Our Work', href: '/portfolio' }}
    />
  </main>
  <Footer />
</BaseLayout>
