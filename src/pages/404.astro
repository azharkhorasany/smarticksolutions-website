---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { NAV_LINKS } from '../config/site';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Return to the Smartick Solutions homepage."
>
  <Header />
  <main id="main-content">
    <section
      class="relative overflow-hidden min-h-[70vh] flex items-center"
      style="background: linear-gradient(135deg, #070838 0%, #0f1360 55%, #1B1F8A 100%);"
    >
      <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.10) 1px, transparent 1px); background-size: 26px 26px;" aria-hidden="true"></div>
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 80% at 95% 5%, rgba(232,0,29,0.14) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-custom relative z-10 py-24">
        <div class="max-w-xl">
          <p class="text-scarlet font-bold text-sm uppercase tracking-widest mb-4">404 — Page Not Found</p>
          <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-none mb-6" style="letter-spacing: -0.04em;">
            This page doesn't exist.
          </h1>
          <p class="text-gray-300 text-lg leading-relaxed mb-10">
            The URL you followed may be mistyped or the page may have moved. Try one of the links below.
          </p>

          <div class="flex flex-wrap gap-3 mb-12">
            <a href="/" class="btn-primary">Back to Homepage</a>
            <a href="/contact" class="btn-outline-white">Contact Us</a>
          </div>

          <div class="border-t border-white/10 pt-8">
            <p class="text-gray-400 text-sm mb-4">Or go directly to:</p>
            <nav class="flex flex-wrap gap-x-6 gap-y-2">
              {NAV_LINKS.map(link => (
                <a href={link.href} class="text-gray-300 hover:text-white text-sm transition-colors">
                  {link.label}
                </a>
              ))}
            </nav>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
