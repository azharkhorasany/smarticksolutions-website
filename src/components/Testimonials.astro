---
const testimonials = [
  {
    quote: 'Smartick Solutions transformed how we run our operations. The custom system they built replaced three separate tools we were cobbling together — and the time saving has been extraordinary. They were professional, transparent, and delivered exactly what they promised.',
    name: 'James Mitchell',
    role: 'CEO',
    company: 'TechStart Ltd',
    initials: 'JM',
    colour: 'bg-navy',
  },
  {
    quote: 'The integration work they delivered saved us around eight hours a week in manual data entry. It just works — our Xero and Salesforce are always in sync. Genuinely life-changing for the finance team.',
    name: 'Sarah Chen',
    role: 'Operations Manager',
    company: 'RetailPro UK',
    initials: 'SC',
    colour: 'bg-scarlet',
  },
  {
    quote: "Professional from day one. They were upfront about the scope, delivered exactly on time, and the app has had zero issues since launch. We'll be using Smartick Solutions for all our future development.",
    name: 'David Okafor',
    role: 'Founder',
    company: 'FinTrack Solutions',
    initials: 'DO',
    colour: 'bg-navy-mid',
  },
];

const featured = testimonials[0];
const others   = testimonials.slice(1);

const starPath = 'M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z';
---

<section class="relative py-20 md:py-28 bg-navy-dark overflow-hidden" id="testimonials">

  <!-- Dot grid -->
  <div class="absolute inset-0 t-dots" aria-hidden="true"></div>
  <!-- Mesh -->
  <div class="absolute inset-0 t-mesh" aria-hidden="true"></div>

  <!-- Geometric: floating rings left side -->
  <div class="absolute left-0 top-1/2 -translate-y-1/2 pointer-events-none hidden lg:block" aria-hidden="true">
    <svg width="220" height="440" viewBox="0 0 220 440" fill="none" class="opacity-10">
      <circle cx="0" cy="220" r="180" stroke="white" stroke-width="1"/>
      <circle cx="0" cy="220" r="130" stroke="white" stroke-width="1"/>
      <circle cx="0" cy="220" r="80"  stroke="white" stroke-width="1.5"/>
      <circle cx="0" cy="220" r="30"  fill="white" fill-opacity="0.15"/>
      <line x1="0" y1="40"  x2="0" y2="100" stroke="white" stroke-width="1"/>
      <line x1="0" y1="340" x2="0" y2="400" stroke="white" stroke-width="1"/>
      <line x1="80" y1="220" x2="140" y2="220" stroke="white" stroke-width="1"/>
      <circle cx="130" cy="220" r="5" fill="white"/>
      <circle cx="0"   cy="40"  r="4" fill="white"/>
      <circle cx="0"   cy="400" r="4" fill="white"/>
    </svg>
  </div>

  <!-- Geometric: hexagons right side -->
  <div class="absolute right-8 top-10 pointer-events-none hidden lg:block" aria-hidden="true">
    <svg width="160" height="300" viewBox="0 0 160 300" fill="none" class="opacity-10">
      <polygon points="80,10 140,45 140,115 80,150 20,115 20,45" stroke="white" stroke-width="1.5" fill="none"/>
      <polygon points="80,30 120,53 120,99 80,122 40,99 40,53"  stroke="white" stroke-width="1"   fill="none"/>
      <polygon points="130,200 155,214 155,242 130,256 105,242 105,214" stroke="white" stroke-width="1.5" fill="none"/>
      <circle cx="80"  cy="80"  r="6" fill="white" fill-opacity="0.4"/>
      <circle cx="130" cy="228" r="4" fill="white" fill-opacity="0.4"/>
      <line x1="80" y1="150" x2="130" y2="200" stroke="white" stroke-width="1"/>
    </svg>
  </div>

  <!-- Glow blobs -->
  <div class="absolute top-0 right-1/4 w-96 h-64 t-blob-blue" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-1/4 w-72 h-48 t-blob-red"  aria-hidden="true"></div>

  <div class="container-custom relative z-10">

    <!-- Section header -->
    <div class="text-center reveal mb-14">
      <span class="section-label-center text-scarlet" style="color:#E8001D;">Client Testimonials</span>
      <h2 class="section-title text-white mt-3">Trusted by UK Businesses</h2>
      <p class="text-gray-400 mt-4 max-w-xl mx-auto leading-relaxed">
        We measure success by the results we deliver. Here's what our clients say.
      </p>
    </div>

    <!-- Featured testimonial -->
    <blockquote class="relative bg-white/[0.05] border border-white/10 rounded-2xl p-8 md:p-12 mb-6 reveal">
      <!-- Decorative large quote mark -->
      <div class="absolute top-8 left-8 md:top-10 md:left-10 text-scarlet/25" aria-hidden="true">
        <svg class="h-14 w-14 md:h-20 md:w-20" fill="currentColor" viewBox="0 0 32 32">
          <path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7.333C7.333 11.422 8.755 10 10 10V8zm14 0c-3.314 0-6 2.686-6 6v10h10V14h-6.667C21.333 11.422 22.755 10 24 10V8z"/>
        </svg>
      </div>

      <div class="pl-0 md:pl-16">
        <!-- Stars -->
        <div class="flex gap-1 mb-6" aria-label="5 out of 5 stars">
          {Array(5).fill(0).map(() => (
            <svg class="h-5 w-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d={starPath}/>
            </svg>
          ))}
        </div>

        <p class="text-white text-xl md:text-2xl font-medium leading-relaxed italic mb-8" style="letter-spacing: -0.01em;">
          "{featured.quote}"
        </p>

        <footer class="flex items-center gap-4">
          <div class={`w-12 h-12 rounded-full ${featured.colour} flex items-center justify-center text-white font-bold flex-shrink-0`}>
            {featured.initials}
          </div>
          <div>
            <p class="text-white font-bold">{featured.name}</p>
            <p class="text-gray-400 text-sm">{featured.role}, {featured.company}</p>
          </div>
        </footer>
      </div>
    </blockquote>

    <!-- Two smaller testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {others.map((t, i) => (
        <blockquote class="bg-white/[0.04] border border-white/10 rounded-2xl p-8 reveal" style={`transition-delay: ${(i + 1) * 120}ms`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-4" aria-label="5 out of 5 stars">
            {Array(5).fill(0).map(() => (
              <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d={starPath}/>
              </svg>
            ))}
          </div>

          <p class="text-gray-300 text-base leading-relaxed italic mb-6">"{t.quote}"</p>

          <footer class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full ${t.colour} flex items-center justify-center text-white text-xs font-bold flex-shrink-0`}>
              {t.initials}
            </div>
            <div>
              <p class="text-white font-semibold text-sm">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.role}, {t.company}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .t-dots {
    background-image: radial-gradient(circle, rgba(255,255,255,0.13) 1.5px, transparent 1.5px);
    background-size: 30px 30px;
  }
  .t-mesh {
    background:
      radial-gradient(ellipse 70% 60% at 80% 20%, rgba(43,48,196,0.4)  0%, transparent 65%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(27,31,138,0.45) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 50% 50%, rgba(8,12,60,0.3)    0%, transparent 70%);
  }
  .t-blob-blue {
    background: radial-gradient(ellipse, rgba(59,68,220,0.3) 0%, transparent 70%);
    filter: blur(60px);
  }
  .t-blob-red {
    background: radial-gradient(ellipse, rgba(232,0,29,0.12) 0%, transparent 70%);
    filter: blur(70px);
  }
</style>
