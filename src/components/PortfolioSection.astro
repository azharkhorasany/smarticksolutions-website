---
import { portfolioItems } from '../data/portfolio';

interface Props {
  preview?: boolean;
}
const { preview = false } = Astro.props;

const items = preview ? portfolioItems.slice(0, 3) : portfolioItems;

const categoryColours: Record<string, string> = {
  'Website Development':    'bg-navy-100 text-navy-800',
  'Bespoke Software':       'bg-navy-100 text-navy-900',
  'Mobile App Development': 'bg-scarlet-100 text-scarlet-800',
  'Integration Services':   'bg-navy-200 text-navy-900',
  'Architecture Consultation': 'bg-scarlet-50 text-scarlet-700',
};
---

<section class={`py-20 md:py-28 ${preview ? 'bg-navy-50' : 'bg-navy-50'}`} id="portfolio">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 reveal">
      <div>
        <p class="section-label">Our Work</p>
        <h2 class="section-title">{preview ? 'Recent Projects' : 'Portfolio & Case Studies'}</h2>
        {preview && (
          <p class="section-subtitle">A selection of projects we've delivered for clients across the UK.</p>
        )}
      </div>
      {preview && (
        <a href="/portfolio" class="btn-secondary flex-shrink-0">
          View All Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {items.map((item, i) => (
        <article class="card overflow-hidden group reveal" style={`transition-delay: ${i * 80}ms`}>
          <a href={`/portfolio/${item.slug}`} class="block" aria-label={`View case study: ${item.title}`}>
            <!-- Visual header -->
            <div class={`bg-gradient-to-br ${item.gradient} h-44 flex items-end p-5`}>
              <span class="text-xs font-semibold px-3 py-1 rounded-full bg-white/20 text-white backdrop-blur-sm">
                {item.category}
              </span>
            </div>

            <div class="p-6">
              <h3 class="text-base font-extrabold text-navy-950 mb-2 group-hover:text-scarlet-600 transition-colors" style="letter-spacing:-0.01em">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">{item.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {item.tags.map((tag) => (
                  <span class="text-xs px-2.5 py-1 bg-navy-50 text-navy-700 border border-navy-100 rounded-full font-medium">{tag}</span>
                ))}
              </div>
              <span class="inline-flex items-center gap-1.5 text-xs font-bold text-scarlet group-hover:gap-2.5 transition-all duration-200">
                View case study
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>

    {!preview && (
      <div class="mt-14 text-center reveal">
        <p class="text-gray-500 mb-4">Have a project in mind?</p>
        <a href="/contact" class="btn-primary">Start a Conversation</a>
      </div>
    )}
  </div>
</section>
