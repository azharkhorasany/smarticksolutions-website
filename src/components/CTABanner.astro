---
interface Props {
  title?: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  title = 'Ready to Transform Your Business With Technology?',
  subtitle = "Let's talk about your project. A free 30-minute discovery call costs you nothing and could change everything.",
  primaryCta = { label: 'Get a Free Quote', href: '/contact' },
  secondaryCta = { label: 'View Our Services', href: '/services' },
} = Astro.props;
---

<section class="relative bg-scarlet py-20 md:py-24 overflow-hidden" aria-labelledby="cta-heading">

  <!-- Dot grid -->
  <div class="absolute inset-0 cta-dots" aria-hidden="true"></div>

  <!-- Mesh gradient -->
  <div class="absolute inset-0 cta-mesh" aria-hidden="true"></div>

  <!-- Diagonal grid lines -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="w-full h-full opacity-10" viewBox="0 0 1440 300" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Diagonal stripes -->
      <line x1="-100" y1="0"   x2="400"  y2="300" stroke="white" stroke-width="1"/>
      <line x1="100"  y1="0"   x2="600"  y2="300" stroke="white" stroke-width="1"/>
      <line x1="300"  y1="0"   x2="800"  y2="300" stroke="white" stroke-width="1"/>
      <line x1="500"  y1="0"   x2="1000" y2="300" stroke="white" stroke-width="1"/>
      <line x1="700"  y1="0"   x2="1200" y2="300" stroke="white" stroke-width="1"/>
      <line x1="900"  y1="0"   x2="1400" y2="300" stroke="white" stroke-width="1"/>
      <line x1="1100" y1="0"   x2="1600" y2="300" stroke="white" stroke-width="1"/>
      <line x1="1300" y1="0"   x2="1800" y2="300" stroke="white" stroke-width="1"/>
    </svg>
  </div>

  <!-- Corner geometric rings -->
  <div class="absolute -top-20 -left-20 pointer-events-none" aria-hidden="true">
    <svg width="300" height="300" viewBox="0 0 300 300" fill="none" class="opacity-15">
      <circle cx="0"   cy="0" r="250" stroke="white" stroke-width="1"/>
      <circle cx="0"   cy="0" r="180" stroke="white" stroke-width="1"/>
      <circle cx="0"   cy="0" r="110" stroke="white" stroke-width="1.5"/>
      <circle cx="0"   cy="0" r="50"  stroke="white" stroke-width="1"/>
      <circle cx="110" cy="0" r="6"   fill="white"/>
      <circle cx="0"   cy="110" r="6" fill="white"/>
    </svg>
  </div>
  <div class="absolute -bottom-20 -right-20 pointer-events-none" aria-hidden="true">
    <svg width="300" height="300" viewBox="0 0 300 300" fill="none" class="opacity-15">
      <circle cx="300" cy="300" r="250" stroke="white" stroke-width="1"/>
      <circle cx="300" cy="300" r="180" stroke="white" stroke-width="1"/>
      <circle cx="300" cy="300" r="110" stroke="white" stroke-width="1.5"/>
      <circle cx="300" cy="300" r="50"  stroke="white" stroke-width="1"/>
      <circle cx="190" cy="300" r="6"   fill="white"/>
      <circle cx="300" cy="190" r="6"   fill="white"/>
    </svg>
  </div>

  <!-- Glow blobs -->
  <div class="absolute top-1/2 left-1/4  -translate-y-1/2 w-96 h-96 cta-blob" aria-hidden="true"></div>
  <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-72 h-72 cta-blob" aria-hidden="true"></div>

  <div class="container-custom relative z-10 text-center">
    <div class="max-w-3xl mx-auto reveal">
      <h2 id="cta-heading" class="text-3xl md:text-5xl font-extrabold text-white text-balance">
        {title}
      </h2>
      <p class="text-red-100 text-lg mt-5 leading-relaxed">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a href={primaryCta.href} class="inline-flex items-center justify-center gap-2 bg-white text-scarlet px-8 py-4 rounded-lg font-bold hover:bg-gray-50 transition-colors duration-200 text-base">
          {primaryCta.label}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={secondaryCta.href} class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-scarlet transition-colors duration-200 text-base">
          {secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-dots {
    background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
  }
  .cta-mesh {
    background:
      radial-gradient(ellipse 60% 80% at 0%   50%, rgba(200,0,10,0.5)   0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 100% 50%, rgba(160,0,15,0.5)   0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 50%  0%,  rgba(255,60,60,0.25) 0%, transparent 60%);
  }
  .cta-blob {
    background: radial-gradient(ellipse, rgba(255,255,255,0.08) 0%, transparent 70%);
    filter: blur(50px);
  }
</style>
