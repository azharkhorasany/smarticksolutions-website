---
interface Service {
  id: string;
  icon: string;
  title: string;
  description: string;
  features: string[];
}

const services: Service[] = [
  {
    id: 'bespoke',
    icon: 'code',
    title: 'Bespoke Software Development',
    description: 'Custom-built applications tailored to your exact business requirements. From enterprise systems to automation tools, we deliver software that works exactly the way your business needs it to — not a generic product retrofitted to your processes.',
    features: ['Web applications & portals', 'Business process automation', 'Admin systems & dashboards', 'Data management platforms'],
  },
  {
    id: 'architecture',
    icon: 'blueprint',
    title: 'Software Architecture Consultation',
    description: 'Expert guidance on system design, technology selection, and scalability planning. Whether you are starting fresh or scaling an existing platform, we help you make the right decisions before writing a single line of code.',
    features: ['System design & planning', 'Technology stack selection', 'Scalability assessments', 'Code & architecture reviews'],
  },
  {
    id: 'integration',
    icon: 'link',
    title: 'Integration Services',
    description: 'Seamlessly connect your systems with third-party APIs, payment gateways, CRMs, ERPs, and more. Eliminate data silos and manual processes with reliable, well-tested integrations that just work.',
    features: ['Third-party API integration', 'Payment gateway setup', 'CRM & ERP connectors', 'Legacy system bridges'],
  },
  {
    id: 'mobile',
    icon: 'mobile',
    title: 'Mobile App Development',
    description: 'Cross-platform and native mobile applications for iOS and Android. We deliver performant, polished apps that your customers and staff will actually want to use — and that reflect your brand with pride.',
    features: ['iOS & Android apps', 'Cross-platform (React Native / MAUI)', 'App Store & Play Store submission', 'Ongoing support & updates'],
  },
  {
    id: 'websites',
    icon: 'globe',
    title: 'Website & E-commerce Development',
    description: 'Modern, responsive websites and full e-commerce solutions built to convert visitors into customers. Every site is optimised for performance, accessibility, and search — because a beautiful site that nobody finds is worthless.',
    features: ['Corporate & marketing sites', 'E-commerce stores', 'Headless CMS solutions', 'SEO & performance optimisation'],
  },
];

const iconPaths: Record<string, string> = {
  code:      'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  blueprint: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  link:      'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  mobile:    'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
  globe:     'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
};

const accentGradients = [
  'from-navy to-navy-dark',
  'from-navy-dark to-navy-mid',
  'from-navy-mid to-navy',
  'from-navy to-navy-dark',
  'from-navy-dark to-navy-mid',
];
---

<section class="py-20 md:py-28 bg-white" id="services">
  <div class="container-custom">

    <!-- Section header -->
    <div class="reveal mb-14 max-w-3xl">
      <p class="section-label">What We Do</p>
      <h2 class="section-title">Services Built Around<br/>Your Business</h2>
      <p class="section-subtitle">
        We don't do one-size-fits-all. Every engagement starts with understanding your specific challenges — and ends with a solution designed around them.
      </p>
    </div>

    <!-- Alternating feature blocks -->
    <div class="space-y-5">
      {services.map((service, i) => (
        <article
          id={service.id}
          class="grid grid-cols-1 lg:grid-cols-5 rounded-2xl overflow-hidden border border-gray-100 shadow-sm reveal group"
          style={`transition-delay: ${i * 60}ms`}
        >

          <!-- Visual panel -->
          <div class={`relative lg:col-span-2 bg-navy-dark flex items-center justify-center min-h-[220px] lg:min-h-0 overflow-hidden ${i % 2 === 1 ? 'lg:order-last' : ''}`}>
            <!-- Dot grid -->
            <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.10) 1px, transparent 1px); background-size: 26px 26px;" aria-hidden="true"></div>
            <!-- Glow -->
            <div class="absolute inset-0" style="background: radial-gradient(ellipse 65% 65% at 50% 50%, rgba(232,0,29,0.13) 0%, transparent 65%);" aria-hidden="true"></div>
            <!-- Large ghost number -->
            <span class="absolute select-none pointer-events-none font-black text-white/[0.05]" style="font-size: 9rem; line-height: 1; top: 50%; left: 50%; transform: translate(-50%, -50%);" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <!-- Icon container -->
            <div class="relative z-10 flex flex-col items-center gap-3">
              <div class="w-20 h-20 rounded-2xl bg-white/[0.06] border border-white/20 flex items-center justify-center group-hover:border-scarlet/60 group-hover:bg-scarlet/10 transition-all duration-300">
                <svg class="h-10 w-10 text-white group-hover:text-scarlet transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
                </svg>
              </div>
              <span class="text-white/40 text-xs font-bold uppercase tracking-widest">Service {String(i + 1).padStart(2, '0')}</span>
            </div>
          </div>

          <!-- Text panel -->
          <div class={`lg:col-span-3 bg-white p-8 lg:p-12 flex flex-col justify-center ${i % 2 === 1 ? 'lg:order-first' : ''}`}>
            <span class="badge bg-scarlet/10 text-scarlet mb-5">{String(i + 1).padStart(2, '0')} / {String(services.length).padStart(2, '0')}</span>
            <h3 class="text-2xl md:text-3xl font-extrabold text-navy-dark mb-4 leading-tight" style="letter-spacing: -0.02em;">
              {service.title}
            </h3>
            <p class="text-gray-500 leading-relaxed mb-6">{service.description}</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 mb-8">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2.5 text-sm text-gray-700 font-medium">
                  <svg class="h-4 w-4 text-scarlet flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href={`/services#${service.id}`}
              class="group/link inline-flex items-center gap-2 text-sm font-bold text-scarlet hover:gap-3 transition-all duration-200"
            >
              Explore this service
              <svg class="h-4 w-4 group-hover/link:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="mt-10 reveal">
      <a href="/services" class="btn-secondary">
        View All Services in Detail
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
