---
import { SITE, NAV_LINKS } from '../config/site';

const services = [
  { label: 'Bespoke Software Development', href: '/services#bespoke' },
  { label: 'Software Architecture', href: '/services#architecture' },
  { label: 'Integration Services', href: '/services#integration' },
  { label: 'Mobile App Development', href: '/services#mobile' },
  { label: 'Website Development', href: '/services#websites' },
];

const year = new Date().getFullYear();
---

<footer class="relative bg-navy-dark text-gray-300 overflow-hidden">

  <!-- ── Background decorations ───────────────────────────── -->

  <!-- Dot grid -->
  <div class="absolute inset-0 f-dots" aria-hidden="true"></div>
  <!-- Mesh gradient -->
  <div class="absolute inset-0 f-mesh" aria-hidden="true"></div>

  <!-- Circuit SVG — bottom left -->
  <div class="absolute bottom-0 left-0 pointer-events-none hidden md:block" aria-hidden="true">
    <svg width="420" height="340" viewBox="0 0 420 340" fill="none" class="opacity-[0.12]">
      <!-- Vertical + horizontal grid -->
      <line x1="80"  y1="0"   x2="80"  y2="340" stroke="white" stroke-width="1"/>
      <line x1="200" y1="0"   x2="200" y2="340" stroke="white" stroke-width="1"/>
      <line x1="320" y1="0"   x2="320" y2="340" stroke="white" stroke-width="1"/>
      <line x1="0"   y1="80"  x2="420" y2="80"  stroke="white" stroke-width="1"/>
      <line x1="0"   y1="200" x2="420" y2="200" stroke="white" stroke-width="1"/>
      <line x1="0"   y1="300" x2="420" y2="300" stroke="white" stroke-width="1"/>
      <!-- Junction dots -->
      <circle cx="80"  cy="80"  r="5" fill="white"/>
      <circle cx="200" cy="80"  r="5" fill="white"/>
      <circle cx="320" cy="80"  r="5" fill="white"/>
      <circle cx="80"  cy="200" r="8" fill="white"/>
      <circle cx="200" cy="200" r="5" fill="white"/>
      <circle cx="320" cy="200" r="5" fill="white"/>
      <circle cx="80"  cy="300" r="5" fill="white"/>
      <circle cx="200" cy="300" r="5" fill="white"/>
      <!-- Circuit traces -->
      <path d="M 80 80 L 140 80 L 140 140 L 200 140 L 200 200" stroke="white" stroke-width="2"/>
      <path d="M 200 80 L 260 80 L 260 200 L 320 200" stroke="white" stroke-width="1.5"/>
      <path d="M 80 200 L 80 260 L 140 260 L 140 300 L 200 300" stroke="white" stroke-width="1.5"/>
      <!-- Mini chip -->
      <rect x="106" y="106" width="68" height="68" rx="6" stroke="white" stroke-width="1.5" fill="none"/>
      <rect x="118" y="118" width="44" height="44" rx="3" stroke="white" stroke-width="1"   fill="white" fill-opacity="0.05"/>
      <!-- Chip pins -->
      <line x1="106" y1="118" x2="90"  y2="118" stroke="white" stroke-width="1.5"/>
      <line x1="106" y1="130" x2="90"  y2="130" stroke="white" stroke-width="1.5"/>
      <line x1="106" y1="142" x2="90"  y2="142" stroke="white" stroke-width="1.5"/>
      <line x1="174" y1="118" x2="190" y2="118" stroke="white" stroke-width="1.5"/>
      <line x1="174" y1="130" x2="190" y2="130" stroke="white" stroke-width="1.5"/>
      <line x1="174" y1="142" x2="190" y2="142" stroke="white" stroke-width="1.5"/>
      <!-- Accent circles -->
      <circle cx="320" cy="80"  r="22" stroke="white" stroke-width="1" fill="none"/>
      <circle cx="320" cy="80"  r="10" fill="white" fill-opacity="0.2"/>
    </svg>
  </div>

  <!-- Circuit SVG — top right -->
  <div class="absolute top-0 right-0 pointer-events-none hidden md:block" aria-hidden="true">
    <svg width="300" height="250" viewBox="0 0 300 250" fill="none" class="opacity-[0.10]">
      <line x1="0"   y1="60"  x2="300" y2="60"  stroke="white" stroke-width="1"/>
      <line x1="0"   y1="160" x2="300" y2="160" stroke="white" stroke-width="1"/>
      <line x1="80"  y1="0"   x2="80"  y2="250" stroke="white" stroke-width="1"/>
      <line x1="220" y1="0"   x2="220" y2="250" stroke="white" stroke-width="1"/>
      <circle cx="80"  cy="60"  r="5" fill="white"/>
      <circle cx="220" cy="60"  r="5" fill="white"/>
      <circle cx="80"  cy="160" r="5" fill="white"/>
      <circle cx="220" cy="160" r="8" fill="white"/>
      <path d="M 220 60 L 220 110 L 150 110 L 150 160 L 80 160" stroke="white" stroke-width="2"/>
      <circle cx="150" cy="110" r="4" fill="white"/>
      <circle cx="300" cy="160" r="18" stroke="white" stroke-width="1.5" fill="none"/>
      <circle cx="300" cy="160" r="8"  fill="white" fill-opacity="0.2"/>
    </svg>
  </div>

  <!-- Glow blobs -->
  <div class="absolute bottom-0 left-1/3  w-96 h-64 f-blob-blue" aria-hidden="true"></div>
  <div class="absolute top-0   right-1/4 w-72 h-48 f-blob-red"  aria-hidden="true"></div>

  <!-- ── Content ────────────────────────────────────────────── -->
  <div class="container-custom py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <img src="/logo.png" alt={SITE.name} class="h-10 w-auto mb-4" style="filter: brightness(0) invert(1);" />
        <p class="text-gray-400 mt-4 max-w-sm leading-relaxed">
          Smart technology solutions for UK businesses. From bespoke software to mobile apps and integrations — we build what your business actually needs.
        </p>
        <div class="flex gap-4 mt-6">
          <a
            href={SITE.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg bg-navy text-white hover:bg-scarlet transition-colors duration-200"
            aria-label="Smartick Solutions on LinkedIn"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          {NAV_LINKS.map(({ label, href }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">{label}</a>
            </li>
          ))}
          <li>
            <a href="/contact" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-3">
          {services.map(({ label, href }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact strip -->
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex flex-col sm:flex-row gap-4 text-sm text-gray-400">
        <a href={`tel:${SITE.phone}`} class="hover:text-white transition-colors flex items-center gap-2">
          <svg class="h-4 w-4 text-scarlet" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {SITE.phone}
        </a>
        <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors flex items-center gap-2">
          <svg class="h-4 w-4 text-scarlet" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {SITE.email}
        </a>
      </div>
      <div class="text-xs text-gray-500">
        <p>© {year} {SITE.name}. All rights reserved.</p>
        <p>{SITE.registered}. Company No. 12768446</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .f-dots {
    background-image: radial-gradient(circle, rgba(255,255,255,0.12) 1.5px, transparent 1.5px);
    background-size: 30px 30px;
  }
  .f-mesh {
    background:
      radial-gradient(ellipse 70% 60% at 10% 80%, rgba(43,48,196,0.4)  0%, transparent 65%),
      radial-gradient(ellipse 50% 50% at 90% 20%, rgba(27,31,138,0.35) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 50% 50%, rgba(8,12,60,0.25)   0%, transparent 70%),
      radial-gradient(ellipse 30% 30% at 5%  10%, rgba(232,0,29,0.06)  0%, transparent 55%);
  }
  .f-blob-blue {
    background: radial-gradient(ellipse, rgba(43,48,196,0.3) 0%, transparent 70%);
    filter: blur(70px);
  }
  .f-blob-red {
    background: radial-gradient(ellipse, rgba(232,0,29,0.08) 0%, transparent 70%);
    filter: blur(60px);
  }
</style>
