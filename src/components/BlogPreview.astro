---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const categoryColours: Record<string, string> = {
  'Software Development': 'bg-blue-100 text-blue-700',
  'Integration Services': 'bg-emerald-100 text-emerald-700',
  'Mobile Development': 'bg-red-100 text-red-700',
};
---

<section class="py-20 md:py-28 bg-gray-50" id="blog-preview">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 reveal">
      <div>
        <p class="section-label">Insights</p>
        <h2 class="section-title">From the Blog</h2>
        <p class="section-subtitle">Practical insights on software development, technology strategy, and digital transformation.</p>
      </div>
      <a href="/blog" class="btn-secondary flex-shrink-0">
        All Articles
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post, i) => {
        const categoryClass = categoryColours[post.data.category] ?? 'bg-gray-100 text-gray-700';
        const formattedDate = post.data.pubDate.toLocaleDateString('en-GB', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        });

        return (
          <article class="card group overflow-hidden reveal" style={`transition-delay: ${i * 80}ms`}>
            <!-- Colour band -->
            <div class="h-2 bg-gradient-to-r from-navy to-scarlet"></div>
            <div class="p-7">
              <div class="flex items-center gap-3 mb-4">
                <span class={`text-xs font-semibold px-3 py-1 rounded-full ${categoryClass}`}>
                  {post.data.category}
                </span>
                {post.data.readingTime && (
                  <span class="text-xs text-gray-400">{post.data.readingTime} min read</span>
                )}
              </div>

              <h3 class="font-bold text-navy-dark leading-snug mb-3 group-hover:text-scarlet transition-colors">
                <a href={`/blog/${post.slug}`} class="hover:underline underline-offset-2">
                  {post.data.title}
                </a>
              </h3>

              <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 mb-5">
                {post.data.description}
              </p>

              <div class="flex items-center justify-between text-xs text-gray-400">
                <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
                <a
                  href={`/blog/${post.slug}`}
                  class="text-scarlet font-semibold hover:underline flex items-center gap-1"
                >
                  Read more
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
